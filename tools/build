#!/usr/bin/env bash
set -euo pipefail
shopt -s extglob globstar nullglob

SOURCE_ROOT=$(realpath "$(dirname "${BASH_SOURCE[0]}")/..")
cd "${SOURCE_ROOT}"

ROOT=${ROOT:-$SOURCE_ROOT}
TOOLS_DIR=${TOOLS_DIR:-$ROOT/tools}
PUBLIC_DIR=${PUBLIC_DIR:-$ROOT/public}
STATIC_DIR=${STATIC_DIR:-$ROOT/static}
DATA_DIR=${DATA_DIR:-$ROOT/data}
PAGES_DIR=${PAGES_DIR:-$ROOT/pages}
ARTICLES_DIR=${ARTICLES_DIR:-$ROOT/articles}
COMPONENTS_DIR=${COMPONENTS_DIR:-$ROOT/templates/components}
TRANSFORMS_DIR=${TRANSFORMS_DIR:-$ROOT/transforms}

ARTICLE_TEMPLATE=${ARTICLE_TEMPLATE:-$ROOT/templates/article.html}
PAGE_TEMPLATE=${PAGE_TEMPLATE:-$ROOT/templates/page.html}
SITE_DATA=${SITE_DATA:-$DATA_DIR/site.json}

GOMPLATE_FLAGS=${GOMPLATE_FLAGS:-}
CMARK_FLAGS=${CMARK_FLAGS:-}

read -r -a gomplateExtraFlags <<< "$GOMPLATE_FLAGS"
read -r -a cmarkFlags <<< "$CMARK_FLAGS"

validateEnvironment() {
	local -a missing=()
	local -a required=(
		cmark
		git
		gomplate
		htmlq
		jq
		parallel-moreutils
		stat
	)

	if [[ "${MINIFY:-}" != "" ]]; then
		required+=(minify)
	fi
	
	for cmd in "${required[@]}"; do
		if ! command -v "$cmd" &> /dev/null; then
			missing+=("$cmd")
		fi
	done
	
	if (( ${#missing[@]} != 0 )); then
		echo "Error: Missing required commands: ${missing[*]}" >&2
		echo "Run: nix develop" >&2
		return 1
	fi

	if [[ ! -f "$SITE_DATA" ]]; then
		echo "Error: Missing site config: $SITE_DATA" >&2
		return 1
	fi
}

gomplateFlags=(
	"${gomplateExtraFlags[@]}"
	--template "components=$COMPONENTS_DIR"
	-d "site=file://$SITE_DATA"
	--plugin "md=cmark"
	--plugin "title=$TOOLS_DIR/title"
	--plugin "synopsis=$TOOLS_DIR/synopsis"
)

generateArticle() {
	usage 1 generateArticle "<input>"

	local input="$1"
	local isDir=0

	if [[ -d "$input" ]]; then
		input="$input/index.md"
		isDir=1
	fi

	if [[ ! -f "$input" ]]; then
		log "generateArticle: $input not found"
		return 1
	fi

	local filepath="${input}"
	local filename="${input##*/}"
	local extension="${filename##*.}"

	local writtenAt updatedAt slug
	read -r writtenAt updatedAt slug < <("$TOOLS_DIR/article-date" "$filepath")

	local body
	case "$extension" in
	md)
		body=$(cmark "${cmarkFlags[@]}" --nobreaks --unsafe --smart "$filepath")
		;;
	htm|html)
		body=$(< "$filepath")
		;;
	*)
		log "Unknown file extension: $extension"
		return 1
		;;
	esac

	local title
	local synopsis
	title=$("$TOOLS_DIR/title" "$filepath")
	synopsis=$("$TOOLS_DIR/synopsis" "$filepath")

	local hasMore=false
	if (( ${#synopsis} < ${#body} )); then
		hasMore=true
	fi

	mkdir -p "$PUBLIC_DIR/$slug"

	if (( isDir )); then
		cp -r "$(dirname "$filepath")/." "$PUBLIC_DIR/$slug/"
		rm -f "$PUBLIC_DIR/$slug/index.md"
	fi

	jq --null-input \
		--arg slug "$slug" \
		--arg title "$title" \
		--arg synopsisHTML "$synopsis" \
		--arg synopsisText "$(htmlq -t <<< "$synopsis")" \
		--argjson synopsisHasMore "$hasMore" \
		--argjson writtenAt "$writtenAt" \
		--argjson updatedAt "$updatedAt" \
		--arg bodyHTML "$body" \
		--arg bodyText "$(htmlq -t <<< "$body")" \
		'{
			$slug,
			$title,
			$writtenAt,
			$updatedAt,
			synopsis: {
				text: $synopsisText,
				html: $synopsisHTML,
				hasMore: $synopsisHasMore
			},
			body: {
				text: $bodyText,
				html: $bodyHTML
			}
		}' > "$PUBLIC_DIR/$slug/index.json"

	gomplate "${gomplateFlags[@]}" \
		-f "$ARTICLE_TEMPLATE" \
		-o "$PUBLIC_DIR/$slug/index.html" \
		-d "article=file://$(realpath "$PUBLIC_DIR/$slug/index.json")"
}

generatePage() {
	local template="$1"
	local output="$2"
	shift 2
	local extra=("$@")

	mkdir -p "$(dirname "$output")"
	gomplate "${gomplateFlags[@]}" "${extra[@]}" \
		-f "$template" \
		-o "$output"
}

generateConfiguredPage() {
	usage 4 generateConfiguredPage "<page-key>" "<output>" "<id>" "<slug>"

	local pageKey="$1"
	local output="$2"
	local id="$3"
	local slug="$4"
	local source
	local title
	source=$(jq -r --arg pageKey "$pageKey" '.pages[$pageKey].source // empty' "$SITE_DATA")
	title=$(jq -r --arg pageKey "$pageKey" '.pages[$pageKey].title // empty' "$SITE_DATA")

	if [[ -z "$source" ]]; then
		log "generateConfiguredPage: missing source for page: $pageKey"
		return 1
	fi

	if [[ -z "$title" ]]; then
		log "generateConfiguredPage: missing title for page: $pageKey"
		return 1
	fi

	local input="$PAGES_DIR/$source"

	if [[ ! -f "$input" ]]; then
		log "generateConfiguredPage: $input not found"
		return 1
	fi

	local body
	body=$(cmark "${cmarkFlags[@]}" --nobreaks --unsafe --smart "$input")

	mkdir -p "$(dirname "$output")"

	local pageJson
	pageJson="$output.json"
	jq --null-input \
		--arg id "$id" \
		--arg slug "$slug" \
		--arg title "$title" \
		--arg bodyHTML "$body" \
		'{
			$id,
			$slug,
			$title,
			body: {
				html: $bodyHTML
			}
		}' > "$pageJson"

	gomplate "${gomplateFlags[@]}" \
		-f "$PAGE_TEMPLATE" \
		-o "$output" \
		-d "page=file://$(realpath "$pageJson")"
}

generateArticleIndex() {
	for f in "$@"; do
		if [[ "$f" != *".json" ]]; then
			log "generateArticleIndex: expected json file for $f"
			return 1
		fi
	done

	cat "$@" \
		| jq -s 'map(del(.body)) | sort_by(.writtenAt) | reverse' \
		> "$PUBLIC_DIR/articles.json"
}

transform() {
	for f in "$TRANSFORMS_DIR"/*; do
		"$f" "$1"
	done
}

main() {
	while (( "$#" )); do
		case "$1" in
		-m|--minify)
			export MINIFY=1;;
		-h|--help)
			log "Usage: $(basename "$0") [-m|--minify]"
			return;;
		--)
			shift
			break;;
		*)
			break;;
		esac
		shift
	done

	validateEnvironment

	case "${1:-}" in
	article)
		shift
		for f in "$@"; do
			generateArticle "$f"
		done
		;;
	transform)
		shift
		for f in "$@"; do
			transform "$f"
		done
		;;
	index)
		generateArticleIndex "$@"
		;;
	"")
		mkdir -p "$PUBLIC_DIR"
		rm -rf "${PUBLIC_DIR:?}"/*

		articles=( "$ARTICLES_DIR"/* )
		if (( ${#articles[@]} )); then
			parallel-moreutils "$0" article -- "${articles[@]}"
		fi

		articleJSONs=( "$PUBLIC_DIR"/*/index.json )
		if (( ${#articleJSONs[@]} )); then
			generateArticleIndex "${articleJSONs[@]}"
		else
			echo "[]" > "$PUBLIC_DIR/articles.json"
		fi

		generateConfiguredPage "about" "$PUBLIC_DIR/index.html" "home" ""
		generatePage "$ROOT/templates/blog.html" "$PUBLIC_DIR/blog/index.html" \
			-d "articles=file://$(realpath "$PUBLIC_DIR/articles.json")"
		generateConfiguredPage "about" "$PUBLIC_DIR/about/index.html" "about" "about"
		generateConfiguredPage "contact" "$PUBLIC_DIR/contact/index.html" "contact" "contact"
		generateConfiguredPage "donate" "$PUBLIC_DIR/donate/index.html" "donate" "donate"

		cp -r "$STATIC_DIR" "$PUBLIC_DIR/static"

		parallel-moreutils "$0" transform -- "$PUBLIC_DIR"/**/*
		;;
	*)
		log "Unknown item to generate: $1 (wants article|index|transform)"
		return 1;;
	esac
}

log() {
	echo "$@" >&2
}

# usage <min_args> <thing> <args...>
usage() {
	local minArgs="$1"
	shift
	local cmd="$1"
	shift
	if (( "$#" < minArgs )); then
		log "Usage: $cmd $(printf "<%s> " "$@")"
		return 1
	fi
}

main "$@"
